{
  "name": "@itwin/presentation-hierarchies-react",
  "version": "2.0.0-alpha.62",
  "description": "React components based on `@itwin/presentation-hierarchies`",
  "license": "MIT",
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/presentation.git",
    "directory": "packages/hierarchies-react"
  },
  "keywords": [
    "Bentley",
    "Component",
    "Components",
    "EC",
    "ECSQL",
    "Hierarchies",
    "Hierarchy",
    "iModel",
    "iTwin",
    "iTwin.js",
    "Presentation",
    "React",
    "Tree"
  ],
  "type": "module",
  "types": "lib/presentation-hierarchies-react.d.ts",
  "exports": {
    ".": {
      "types": "./lib/presentation-hierarchies-react.d.ts",
      "import": "./lib/presentation-hierarchies-react.js"
    },
    "./stratakit": {
      "types": "./lib/presentation-hierarchies-react-stratakit.d.ts",
      "import": "./lib/presentation-hierarchies-react-stratakit.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run -s typecheck && tsdown && npm run -s build:locale && npm run -s copy",
    "build:locale": "tsc -p tsconfig.utils.json && node ./lib/build/utils/BuildLocale.js",
    "copy": "npm run -s copy:css && npm run -s copy:assets",
    "copy:css": "cpx \"./src/**/*.css\" \"./lib\"",
    "copy:assets": "cpx \"./src/public/**/*\" \"./lib/public\"",
    "clean": "rimraf lib build",
    "cover": "npm -s test",
    "lint": "eslint \"./src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract-api": "betools extract-api --entry=lib/presentation-hierarchies-react-extract --apiReportFolder=./api --apiReportTempFolder=./api/temp --apiSummaryFolder=./api --includeUnexportedApis",
    "check-internal": "node ../../scripts/checkInternal.js --apiSummary ./api/presentation-hierarchies-react-extract.api.md",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "update-extractions": "node ../../scripts/updateExtractions.js --targets=./README.md",
    "check-extractions": "node ../../scripts/updateExtractions.js --targets=./README.md --check",
    "validate-markdowns": "node ../../scripts/validateMarkdowns.js README.md"
  },
  "dependencies": {
    "@itwin/core-bentley": "catalog:itwinjs-core",
    "@itwin/presentation-hierarchies": "workspace:*",
    "@itwin/presentation-shared": "workspace:*",
    "@itwin/unified-selection": "workspace:^",
    "@stratakit/bricks": "catalog:stratakit",
    "@stratakit/structures": "catalog:stratakit",
    "@tanstack/react-virtual": "^3.13.13",
    "classnames": "catalog:react",
    "immer": "^10.2.0",
    "react-compiler-runtime": "catalog:react",
    "react-error-boundary": "catalog:react",
    "rxjs": "catalog:rxjs"
  },
  "peerDependencies": {
    "@stratakit/foundations": "^0.4.7",
    "@stratakit/icons": "^0.3.1",
    "react": "^17.0 || ^18.0",
    "react-dom": "^17.0 || ^18.0"
  },
  "peerDependenciesMeta": {
    "@stratakit/foundations": {
      "optional": true
    },
    "@stratakit/icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@itwin/build-tools": "catalog:build-tools",
    "@itwin/eslint-plugin": "catalog:build-tools",
    "@rolldown/plugin-babel": "catalog:build-tools",
    "@stratakit/foundations": "catalog:stratakit",
    "@stratakit/icons": "catalog:stratakit",
    "@testing-library/dom": "catalog:test-tools",
    "@testing-library/react": "catalog:test-tools",
    "@testing-library/user-event": "catalog:test-tools",
    "@types/node": "catalog:build-tools",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:build-tools",
    "babel-plugin-react-compiler": "catalog:build-tools",
    "@vitest/coverage-v8": "catalog:test-tools",
    "eslint": "catalog:build-tools",
    "eslint-plugin-react": "catalog:build-tools",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "catalog:test-tools",
    "presentation-test-utilities": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "rimraf": "catalog:build-tools",
    "tsdown": "catalog:build-tools",
    "typescript": "catalog:build-tools",
    "vitest": "catalog:test-tools"
  }
}
