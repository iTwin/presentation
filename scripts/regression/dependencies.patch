diff --git a/.pnpmfile.cjs b/.pnpmfile.cjs
index dd4c53ca..591e10cb 100644
--- a/.pnpmfile.cjs
+++ b/.pnpmfile.cjs
@@ -1,3 +1,29 @@
+const corePackages = [
+  "@itwin/appui-abstract",
+  "@itwin/core-backend",
+  "@itwin/core-bentley",
+  "@itwin/core-common",
+  "@itwin/core-electron",
+  "@itwin/core-frontend",
+  "@itwin/core-geometry",
+  "@itwin/core-i18n",
+  "@itwin/core-orbitgt",
+  "@itwin/core-quantity",
+  "@itwin/ecschema-metadata",
+  "@itwin/ecschema-rpcinterface-common",
+  "@itwin/ecschema-rpcinterface-impl",
+  "@itwin/express-server",
+  "@itwin/presentation-backend",
+  "@itwin/presentation-common",
+  "@itwin/presentation-frontend",
+  "@itwin/webgl-compatibility",
+];
+
+const appuiPackages = ["@itwin/appui-react", "@itwin/core-react", "@itwin/components-react", "@itwin/imodel-components-react"];
+
+// Downgrade react to 18.3.1 for regression tests (AppUI < 5.x doesn't support React 19)
+const reactOverrides = { "react": "18.3.1", "react-dom": "18.3.1", "@types/react": "18.3.1", "@types/react-dom": "18.3.1" };
+
 function readPackage(pkg) {
   if (pkg.name === "@artilleryio/sketches-js") {
     // `@artilleryio/sketches-js` specifies `protobufjs` as a devDependency, although it should be a dependency...
@@ -14,11 +40,42 @@ function readPackage(pkg) {
       typescript: `${pkg.peerDependencies["typescript"]} || ^5.7.0`,
     };
   }
+
+  // fix peer dependencies for older itwinjs-core packages
+  if (corePackages.includes(pkg.name) && pkg.peerDependencies) {
+    for (const [key] of Object.entries(pkg.peerDependencies)) {
+      if (corePackages.includes(key)) {
+        pkg.peerDependencies[key] = pkg.version;
+      }
+    }
+  }
+
+  // fix peer dependencies for older appui packages
+  if (appuiPackages.includes(pkg.name) && pkg.peerDependencies) {
+    for (const [key] of Object.entries(pkg.peerDependencies)) {
+      if (appuiPackages.includes(key)) {
+        pkg.peerDependencies[key] = pkg.version;
+      }
+    }
+  }
+
+  // downgrade react dependencies to 18.3.1
+  for (const [reactPkg, version] of Object.entries(reactOverrides)) {
+    if (pkg.dependencies?.[reactPkg]) pkg.dependencies[reactPkg] = version;
+    if (pkg.devDependencies?.[reactPkg]) pkg.devDependencies[reactPkg] = version;
+    if (pkg.peerDependencies?.[reactPkg]) pkg.peerDependencies[reactPkg] = version;
+  }
+
   return pkg;
 }
 
+function updateConfig(config) {
+  return { ...config, strictPeerDependencies: false };
+}
+
 module.exports = {
   hooks: {
     readPackage,
+    updateConfig,
   },
 };
