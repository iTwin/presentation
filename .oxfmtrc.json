{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 160,
  "trailingComma": "all",
  "tabWidth": 2,
  "singleQuote": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "build",
    "lib",
    ".changeset",
    "CHANGELOG.md",
    ".vscode",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    ".azure-pipelines",
    ".github",
    ".husky",
    "api",
    "sample_documents"
  ],
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "options": {
        "objectWrap": "collapse"
      }
    },
    {
      "files": ["**/*"],
      "excludeFiles": [
        "**/learning-snippets/**/*.ts*",
        "**/test/**/setup.ts",
        "**/full-stack-tests/**/setup.ts",
        "apps/test-app/backend/src/main.ts",
        "apps/test-app/frontend/src/index.tsx"
      ],
      "options": {
        "sortImports": {
          "newlinesBetween": false,
          "sortSideEffects": true,
          "groups": [
            "side-effect-imports",
            { "newlinesBetween": true },
            "style-imports",
            { "newlinesBetween": true },
            ["value-builtin", "value-external"],
            "scoped",
            "value-internal",
            ["value-parent", "value-sibling", "value-index"],
            { "newlinesBetween": true },
            "icons",
            { "newlinesBetween": true },
            ["type-builtin", "type-external"],
            "type-scoped",
            "type-import",
            "unknown"
          ],
          "customGroups": [
            { "groupName": "side-effect-imports", "modifiers": ["side_effect"], "elementNamePattern": ["**/*.js", "@*/*"] },
            { "groupName": "icons", "elementNamePattern": ["**/*.svg"] },
            { "groupName": "style-imports", "elementNamePattern": ["**/*.css", "**/*.scss"] },
            { "groupName": "scoped", "modifiers": ["value"], "elementNamePattern": ["@*/**"] },
            { "groupName": "type-scoped", "modifiers": ["type"], "elementNamePattern": ["@*/**"] }
          ]
        }
      }
    }
  ]
}
